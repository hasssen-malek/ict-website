{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/buttons/**",
              "components/content/**",
              "components/forms/**",
              "components/labels/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Inter))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|arrow|disabled|onClick|type|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, arrow, disabled, onClick, type, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|line|solid-light|solid-dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'line' | 'solid-light' | 'solid-dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|accent|interactive|className|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, accent, interactive, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:surface|cell|flat)$/]",
        "message": "<Card> variant must be one of 'surface' | 'cell' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:blue|purple|violet|magenta|orange|tick1|tick3|tick4|tick5)$/]",
        "message": "<Card> accent must be one of 'blue' | 'purple' | 'violet' | 'magenta' | 'orange' | 'tick1' | 'tick3' | 'tick4' | 'tick5'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|checked|defaultChecked|onChange|name|value|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: children, checked, defaultChecked, onChange, name, value, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|onPaper|className|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, accent, onPaper, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:blue|purple|violet|magenta|orange)$/]",
        "message": "<Eyebrow> accent must be one of 'blue' | 'purple' | 'violet' | 'magenta' | 'orange'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|hint|error|multiline|placeholder|type|value|defaultValue|name|disabled|onChange|className|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, required, hint, error, multiline, placeholder, type, value, defaultValue, name, disabled, onChange, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='LineIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|className|key|ref|className|style|children)$/]",
        "message": "<LineIcon> doesn't accept that prop. Declared props: name, size, strokeWidth, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='LineIcon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:cloud|shield|lock|layers|data|network|radar|identity|ai|operations|improve|check|compass|bolt|target|globe|delivery|managed|partnership)$/]",
        "message": "<LineIcon> name must be one of 'cloud' | 'shield' | 'lock' | 'layers' | 'data' | 'network' | 'radar' | 'identity' | 'ai' | 'operations' | 'improve' | 'check' | 'compass' | 'bolt' | 'target' | 'globe' | 'delivery' | 'managed' | 'partnership'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PartnerLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|basePath|onPaper|className|key|ref|className|style|children)$/]",
        "message": "<PartnerLogo> doesn't accept that prop. Declared props: name, basePath, onPaper, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|label|accent|onPaper|className|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, unit, label, accent, onPaper, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:blue|purple|violet|magenta|orange)$/]",
        "message": "<Stat> accent must be one of 'blue' | 'purple' | 'violet' | 'magenta' | 'orange'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|onPaper|className|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, variant, onPaper, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:cap|pill)$/]",
        "message": "<Tag> variant must be one of 'cap' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|href|arrow|onClick|className|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: children, href, arrow, onClick, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticks'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|className|key|ref|className|style|children)$/]",
        "message": "<Ticks> doesn't accept that prop. Declared props: variant, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticks'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:row|sm|bar)$/]",
        "message": "<Ticks> variant must be one of 'row' | 'sm' | 'bar'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
